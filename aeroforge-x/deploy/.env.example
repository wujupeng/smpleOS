# ============================================================
# AeroForge-X Environment Configuration Template
# Copy this file to .env and adjust values for your environment
# ============================================================

# --- Core Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aeroforge_x
POSTGRES_USER=aeroforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- TimescaleDB ---
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_DB=aeroforge_ts
TIMESCALE_USER=aeroforge
TIMESCALE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aeroforge_minio
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET_MODELS=aeroforge-models
MINIO_BUCKET_REPORTS=aeroforge-reports
MINIO_BUCKET_DELIVERABLES=aeroforge-deliverables

# --- NATS JetStream ---
NATS_URL=nats://nats:4222

# --- Keycloak ---
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=aeroforge
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
KEYCLOAK_CLIENT_ID=aeroforge-x
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET

# --- Kong API Gateway ---
KONG_PROXY_URL=http://kong:8000
KONG_ADMIN_URL=http://kong:8001

# --- Service Ports (for direct access in dev) ---
PORT_DESIGN_CENTER=8002
PORT_CAE_CENTER=8003
PORT_DIGITAL_TWIN_CENTER=8004
PORT_BOM_CENTER=8005
PORT_PLM_CENTER=8006
PORT_MES_CENTER=8007
PORT_SUPPLY_CHAIN=8008
PORT_DELIVERY_CENTER=8009
PORT_CERTIFICATION_CENTER=8010
PORT_KNOWLEDGE_CENTER=8011
PORT_PLATFORM_ECOSYSTEM=8012
PORT_DATA_LAKE=8013
PORT_QMS_SERVICE=8014
PORT_TRACE_SERVICE=8015

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000

# --- AI / ML ---
AI_TRAINING_GPU_ENABLED=false
AI_TRAINING_MAX_EPOCHS=100
AI_TRAINING_BATCH_SIZE=32

# --- Digital Twin ---
TWIN_FUSION_ENABLED=true
TWIN_LOOP_FEEDBACK_INTERVAL_SEC=300
TWIN_MULTI_FIDELITY_ENABLED=true

# --- Certification ---
CERTIFICATION_AUTO_VERIFY_ENABLED=true
AIRWORTHINESS_AUTHORITY=FAA

# --- Data Lake ---
DATA_LAKE_RETENTION_DAYS=365
DATA_LAKE_COMPRESSION_ENABLED=true

# --- Multi-Site ---
MULTI_SITE_ENABLED=false
MULTI_SITE_SYNC_INTERVAL_SEC=60

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Security ---
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60

# --- Environment ---
APP_ENV=development
APP_VERSION=4.0.0