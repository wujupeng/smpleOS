# AeroForge-X V6.1 Environment Variables
# Copy to .env.v61 and fill in production values

# PostgreSQL
PG_PASSWORD=aeroforge

# TimescaleDB
TS_PASSWORD=aeroforge_ts

# Neo4j
NEO4J_PASSWORD=aeroforge_neo4j

# MinIO
MINIO_USER=aeroforge
MINIO_SECRET=aeroforge123

# Encryption Master Key (32 bytes for AES-256)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_MASTER_KEY=aeroforge-master-key-32bytes!!